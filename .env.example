# ApplyWise AI - Environment Variables

# Your Gemini API Key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_api_key_here

# The Gemini model to use for the agents (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Set to True to use Vertex AI instead of Google AI Studio
GOOGLE_GENAI_USE_VERTEXAI=False
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1
